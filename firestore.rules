rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        (request.auth.token != null && request.auth.token.email == 'shmalik479@gmail.com') ||
        (request.auth.token != null && request.auth.token.email_verified == true && request.auth.token.email == 'shmalik479@gmail.com')
      );
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidGame(data) {
      return data.keys().hasAll(['title', 'embedUrl', 'createdAt'])
        && data.title is string && data.title.size() <= 1000
        && (!('description' in data) || (data.description is string && data.description.size() <= 10000))
        && (!('thumbnail' in data) || (data.thumbnail is string && data.thumbnail.size() <= 4000))
        && data.embedUrl is string && data.embedUrl.size() <= 4000
        && (!('category' in data) || (data.category is string && data.category.size() <= 100))
        && (!('tags' in data) || (data.tags is list && data.tags.size() <= 100))
        && (!('active' in data) || data.active is bool)
        && (!('plays' in data) || data.plays is number)
        && (!('rating' in data) || data.rating is number)
        && (!('ratingCount' in data) || data.ratingCount is number)
        && data.createdAt is number;
    }
    
    function isValidAdSettings(data) {
      return data.keys().hasAll(['updatedAt'])
        && (!('adsEnabled' in data) || data.adsEnabled is bool)
        && (!('videoEnabled' in data) || data.videoEnabled is bool)
        && (!('bannerEnabled' in data) || data.bannerEnabled is bool)
        && (!('interstitialEnabled' in data) || data.interstitialEnabled is bool)
        && (!('adsterraPublisherId' in data) || data.adsterraPublisherId is string)
        && (!('videoCooldown' in data) || data.videoCooldown is number)
        && (!('bannerInterval' in data) || data.bannerInterval is number)
        && data.updatedAt is number;
    }

    match /games/{gameId} {
      allow get: if isValidId(gameId);
      allow list: if true; // Publicly readable list of games
      
      allow create: if isValidId(gameId) && isAdmin() && isValidGame(incoming());
      
      allow update: if isValidId(gameId) && (isAdmin() || (
        incoming().rating is number 
        && incoming().ratingCount is number
        && incoming().plays is number
      )) && isValidGame(incoming());

      allow delete: if isValidId(gameId) && isAdmin();
    }
    
    match /settings/ads {
      allow read: if true;
      allow write: if isAdmin() && isValidAdSettings(incoming());
    }
    
    match /admins/{userId} {
      allow read: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId && request.auth.token.email == 'shmalik479@gmail.com';
      allow write: if false; 
    }
  }
}
